# ===========================================
# 数据库配置 (Database Configuration)
# ===========================================
DB_HOST=<YOUR_DB_HOST>
DB_PORT=3306
DB_USER=<YOUR_DB_USER>
DB_PASSWORD=<YOUR_DB_PASSWORD>
DB_NAME=ods

# MySQL 连接字符串 (可选)
MYSQL_HOST=${DB_HOST}
MYSQL_USER=${DB_USER}
MYSQL_PASSWORD=${DB_PASSWORD}
MYSQL_DB=${DB_NAME}

# ===========================================
# 抖店 API 配置 (DouDian API)
# ===========================================
DOUDIAN_APP_KEY=<YOUR_DOUdIAN_APP_KEY>
DOUDIAN_APP_SECRET=<YOUR_DOUdIAN_APP_SECRET>
DOUDIAN_ACCESS_TOKEN=<YOUR_ACCESS_TOKEN>

# ===========================================
# 小红书 API 配置 (XiaoHongShu API)
# ===========================================
XHS_APP_KEY=<YOUR_XHS_APP_KEY>
XHS_APP_SECRET=<YOUR_XHS_APP_SECRET>
XHS_ACCESS_TOKEN=<YOUR_XHS_ACCESS_TOKEN>

# ===========================================
# 微信视频号 API 配置 (WeChat Video API)
# ===========================================
WEIXIN_APP_ID=<YOUR_WEIXIN_APP_ID>
WEIXIN_APP_SECRET=<YOUR_WEIXIN_APP_SECRET>

# ===========================================
# 巨量千川 API 配置 (QianChuan API)
# ===========================================
QIANCHUAN_APP_ID=<YOUR_QIANCHUAN_APP_ID>
QIANCHUAN_APP_SECRET=<YOUR_QIANCHUAN_APP_SECRET>
QIANCHUAN_REFRESH_TOKEN=<YOUR_REFRESH_TOKEN>

# ===========================================
# 飞书 API 配置 (Feishu API)
# ===========================================
FEISHU_APP_ID=<YOUR_FEISHU_APP_ID>
FEISHU_APP_SECRET=<YOUR_FEISHU_APP_SECRET>
FEISHU_APP_TOKEN=<YOUR_FEISHU_APP_TOKEN>

# 飞书多维表 ID (可选，按需配置)
FEISHU_TABLE_ID_KOL=<YOUR_TABLE_ID>
FEISHU_TABLE_ID_PRODUCT=<YOUR_TABLE_ID>
FEISHU_TABLE_ID_RANK=<YOUR_TABLE_ID>
FEISHU_TABLE_ID_SCHEDULE=<YOUR_TABLE_ID>

# ===========================================
# 大模型 API 配置 (LLM API)
# ===========================================
# 通义千问 (Qwen)
DASHSCOPE_API_KEY=<YOUR_DASHSCOPE_API_KEY>

# OpenAI (可选)
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_BASE_URL=https://api.openai.com/v1

# ===========================================
# n8n 配置 (n8n Configuration)
# ===========================================
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
GENERIC_TIMEZONE=Asia/Shanghai
TZ=Asia/Shanghai
N8N_DEFAULT_LOCALE=zh-CN
NODE_OPTIONS=--max-old-space-size=6144

# ===========================================
# 爬虫配置 (Crawler Configuration)
# ===========================================
# Chrome 远程调试端口
CHROME_DEBUG_PORT=9222

# RPC 签名服务端口
RPC_SERVER_PORT=50051

# ===========================================
# 其他配置 (Other Configuration)
# ===========================================
# 日志级别
LOG_LEVEL=INFO

# 并发线程数 (可根据服务器性能调整)
MAX_WORKERS=60
